{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/cron/follow-up", "schedule": "0 12 * * *" }
  ],
  "redirects": [
    { "source": "/tournament", "destination": "/tournament/", "permanent": true },
    { "source": "/programs/hub", "destination": "/programs", "permanent": true },
    { "source": "/programs/leagues", "destination": "/programs", "permanent": true },
    { "source": "/programs/open-play", "destination": "/programs", "permanent": true },
    { "source": "/programs/coached-open-play", "destination": "/programs", "permanent": true },
    { "source": "/programs/youth", "destination": "/programs", "permanent": true },
    { "source": "/locations", "destination": "/", "permanent": true },
    { "source": "/locations/rockville", "destination": "/", "permanent": true },
    { "source": "/locations/north-bethesda", "destination": "/", "permanent": true },
    { "source": "/playdate", "destination": "/", "permanent": true },
    { "source": "/playdate/:path*", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/tournament/", "destination": "https://tournamentwebsite.vercel.app/" },
    { "source": "/tournament/:path*", "destination": "https://tournamentwebsite.vercel.app/:path*" }
  ]
}
